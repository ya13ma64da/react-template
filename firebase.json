{
  "firestore": {
    "database": "(default)",
    "location": "asia-northeast2",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },

  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "disallowLegacyRuntimeConfig": true,

      "ignore": [
        "node_modules",
        ".git",
        "*.log"
      ],

      "predeploy": [
        "npm --prefix \"$RESOURCE_DIR\" run build"
      ]
    }
  ],

  "emulators": {
    "auth": {
      "port": 9099
    },

    "functions": {
      "port": 5001
    },

    "firestore": {
      "port": 8080
    },

    "ui": {
      "enabled": true,
      "port": "4000"
    },

    "singleProjectMode": true
  },
  
  "auth": {
    "providers": {
      "anonymous": true,
      "emailPassword": true,
      "googleSignIn": {}
    }
  }
}
